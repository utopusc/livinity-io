{
	"name": "@livos/docker-agent",
	"version": "0.1.0",
	"description": "LivOS outbound Docker agent — proxies Docker API calls over a WebSocket so livinityd can manage remote hosts behind NAT.",
	"private": true,
	"type": "module",
	"main": "dist/index.js",
	"bin": {
		"livos-docker-agent": "dist/index.js"
	},
	"scripts": {
		"build": "tsc",
		"start": "node dist/index.js",
		"dev": "tsx src/index.ts",
		"typecheck": "tsc --noEmit",
		"test": "vitest run"
	},
	"dependencies": {
		"dockerode": "^4.0.2",
		"ws": "^8.16.0"
	},
	"devDependencies": {
		"@types/dockerode": "^3.3.26",
		"@types/node": "^22.0.0",
		"@types/ws": "^8.5.10",
		"tsx": "^4.7.1",
		"typescript": "^5.7.0",
		"vitest": "^2.1.2"
	}
}
